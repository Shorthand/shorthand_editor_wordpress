<?xml version="1.0"?>
<ruleset name="WordPress Coding Standards for Plugins">
    <description>Generally-applicable sniffs for WordPress plugins</description>

    <config name="testVersion" value="7.2-"/>
    <rule ref="PHPCompatibility"/>

    <!-- Use the WordPress standards -->
    <rule ref="WordPress" />
    <!-- <rule ref="WordPress-Core" /> -->
    <!-- <rule ref="WordPress-Extra" /> -->
    <!-- <rule ref="WordPress-Docs" /> -->
    <!-- <rule ref="WordPressVIPMinimum" /> -->
    <!-- <rule ref="WordPress-VIP-Go" /> -->

    <rule ref="Squiz.Commenting.FileComment.Missing">
     <severity>0</severity>
    </rule>

    <rule ref="Squiz.Commenting.FunctionComment.Missing">
     <severity>0</severity>
    </rule>

    <rule ref="Internal.NoCodeFound">
     <severity>0</severity>
    </rule>

    <!-- Check all PHP files in the current directory  -->
    <arg name="extensions" value="php"/>
    <file>.</file>

    <!-- Show progress and sniff codes in all reports -->
    <arg value="ps"/>

    <!-- Exclude the vendor directory to avoid linting external libraries -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/vendor_prefixed/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/firebase/*</exclude-pattern>
</ruleset>